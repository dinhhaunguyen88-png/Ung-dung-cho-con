{
    "meta": {
        "schema_version": "1.1.0",
        "awf_version": "4.0.2",
        "last_updated": "2026-03-15T18:15:00+07:00"
    },
    "project": {
        "name": "Math Buddy",
        "type": "web-app",
        "description": "Ứng dụng học toán & ngoại ngữ cho trẻ em với pet ảo, bảng xếp hạng; Chế độ Giáo viên đầy đủ tính năng Class/Assignment.",
        "status": "phase2-complete",
        "repo": "https://github.com/dinhhaunguyen88-png/Dinh-Hau-Nguyen.git"
    },
    "tech_stack": {
        "frontend": {
            "framework": "React 19",
            "bundler": "Vite 6.4",
            "styling": "TailwindCSS v4",
            "animation": "motion (Framer Motion)",
            "icons": "lucide-react",
            "i18n": "react-i18next + i18next",
            "language": "TypeScript 5.8"
        },
        "backend": {
            "framework": "Express 4",
            "runtime": "tsx (Node.js 22)",
            "database": "Supabase (PostgreSQL) + Local SQLite fallback",
            "auth": "crypto.scrypt hashing for teachers"
        },
        "apis": {
            "ai": "@google/genai (Gemini)"
        }
    },
    "database_schema": {
        "summary": "App lưu: thông tin user, tiến trình học, pet config, classes, members, assignments.",
        "tables": [
            {
                "name": "users",
                "columns": [
                    "id",
                    "name",
                    "avatar",
                    "avatar_color",
                    "xp",
                    "level",
                    "role",
                    "email",
                    "password_hash",
                    "created_at"
                ],
                "description": "Thông tin học sinh/giáo viên"
            },
            {
                "name": "classes",
                "columns": [
                    "id",
                    "name",
                    "teacher_id",
                    "join_code",
                    "created_at"
                ],
                "description": "Lớp học do giáo viên quản lý"
            },
            {
                "name": "class_members",
                "columns": [
                    "id",
                    "class_id",
                    "user_id",
                    "joined_at"
                ],
                "description": "Danh sách học sinh trong lớp"
            },
            {
                "name": "assignments",
                "columns": [
                    "id",
                    "class_id",
                    "title",
                    "subject",
                    "topic",
                    "question_count",
                    "due_date",
                    "created_at"
                ],
                "description": "Bài tập giao cho lớp"
            },
            {
                "name": "progress",
                "columns": [
                    "id",
                    "user_id",
                    "subject",
                    "topic",
                    "correct_answers",
                    "total_questions",
                    "created_at"
                ],
                "description": "Lịch sử làm bài"
            }
        ],
        "relationships_explained": "1 teacher -> N classes. 1 class -> N students (via members). 1 class -> N assignments."
    },
    "api_endpoints": [
        {
            "method": "POST",
            "path": "/api/auth/teacher/register",
            "explained": "Đăng ký giáo viên"
        },
        {
            "method": "POST",
            "path": "/api/auth/teacher/login",
            "explained": "Đăng nhập giáo viên"
        },
        {
            "method": "POST",
            "path": "/api/classes",
            "explained": "Tạo lớp học mới"
        },
        {
            "method": "GET",
            "path": "/api/classes/:teacherId",
            "explained": "Lấy danh sách lớp của GV"
        },
        {
            "method": "POST",
            "path": "/api/classes/join",
            "explained": "HS tham gia lớp bằng mã code"
        },
        {
            "method": "GET",
            "path": "/api/classes/:classId/members",
            "explained": "Lấy danh sách HS trong lớp"
        },
        {
            "method": "POST",
            "path": "/api/assignments",
            "explained": "Giao bài tập mới"
        },
        {
            "method": "GET",
            "path": "/api/teacher/progress/:classId",
            "explained": "Báo cáo progress cả lớp"
        }
    ],
    "features": [
        {
            "name": "Teacher Mode",
            "status": "done",
            "description": "Auth, Class Mgmt, Assignment & Progress tracking hoàn thiện."
        },
        {
            "name": "English Quest Support",
            "status": "done",
            "description": "Hệ thống Quest tiếng Anh với ngân hàng câu hỏi ngẫu nhiên."
        },
        {
            "name": "Pet System",
            "status": "done",
            "description": "Customizable SVG pets with XP progression & evolution."
        }
    ],
    "knowledge_items": {
        "patterns": [
            "Named exports for components",
            "Unified App.tsx router logic",
            "Teacher system uses scrypt hashing"
        ],
        "gotchas": [
            "Supabase uses UUID - match with strings in TS",
            "Backend accessory data may return plain strings (e.g. 'party-hat') instead of JSON arrays; use robust parsing in src/hooks/usePet.ts",
            "Use npm.cmd for PowerShell on Windows"
        ]
    }
}