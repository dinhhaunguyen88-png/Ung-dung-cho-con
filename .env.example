# Frontend-safe Supabase variables
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Server-only Supabase variable
# Recommended for the Express API so authorization is enforced in app code,
# instead of depending on open anon policies.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Server-only session signing secret for teacher auth tokens.
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional AI utilities used by generation scripts
GEMINI_API_KEY="your-gemini-api-key"
